FROM python:3.11-slim
WORKDIR /app
COPY src/interfaces/ai-service/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt
COPY src/interfaces/ai-service ./ai-service
COPY src/infrastructure/ai-service ./infra
ENV PYTHONPATH=/app
EXPOSE 8001
CMD ["uvicorn", "ai-service.main:app", "--host", "0.0.0.0", "--port", "8001"]
