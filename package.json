{
  "name": "ai-learning-platform",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered learning platform — NestJS API with Clean Architecture",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/interfaces/http/main.js",
    "workers": "ts-node -r tsconfig-paths/register src/interfaces/workers/main.ts",
    "cli": "ts-node -r tsconfig-paths/register src/interfaces/cli/main.ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config test/jest-e2e.json",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@aws-sdk/client-s3": "^3.645.0",
    "@mux/mux-node": "^9.0.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@prisma/client": "^5.19.0",
    "@sentry/node": "^8.30.0",
    "@workos-inc/node": "^7.30.0",
    "axios": "^1.7.2",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dd-trace": "^5.20.0",
    "ioredis": "^5.4.1",
    "meilisearch": "^0.43.0",
    "nest-commander": "^3.14.0",
    "pg": "^8.12.0",
    "posthog-node": "^4.2.0",
    "pusher": "^5.2.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^4.0.0",
    "rxjs": "^7.8.1",
    "voyageai": "^0.0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.3",
    "prisma": "^5.19.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.7.0"
}
